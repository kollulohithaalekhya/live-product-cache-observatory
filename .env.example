# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=product_catalog

# Database Connection
DATABASE_URL=postgresql://postgres:postgres@db:5432/product_catalog

# Redis
REDIS_HOST=cache
REDIS_PORT=6379

# API
PORT=8000

# L1 Cache
L1_CACHE_TTL=60
L1_CACHE_MAX_SIZE=1000

# L2 Cache
L2_CACHE_TTL=300